# ==================== Backend Configuration Template ====================

# Server
PORT=3000
NODE_ENV=production

# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017/hardware_pos
# For MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/hardware_pos
MONGO_URI=mongodb://localhost:27017/hardware_pos

# Frontend URL (for CORS)
FRONTEND_URL=https://toshidevpos.netlify.app

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here

# Paystack Configuration
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxx

# Session Secret (generate a secure random string)
SESSION_SECRET=your_secure_session_secret_here

# Emergency Admin Credentials (for first-time setup)
MASTER_USERNAME=emergencyadmin
MASTER_PASSWORD=SecurePassword123!
